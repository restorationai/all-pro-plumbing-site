---
import { getCollection } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import CtaBanner from "~/components/CtaBanner.astro";
import FAQSection from "~/components/FAQSection.astro";
import InternalLinks from "~/components/InternalLinks.astro";
import GoogleMap from "~/components/GoogleMap.astro";
import DispatchCallout from "~/components/ui/DispatchCallout.astro";
import GbpCityProof from "~/components/ui/GbpCityProof.astro";
import { brand } from "~/lib/brand";
import { serviceImage } from "~/lib/images";
import { dispatchSentence, is247 } from "~/lib/dispatch";

export async function getStaticPaths() {
  const locations = await getCollection("locations");
  return locations.map((l) => ({
    params: { area: l.data.area_slug, service: l.data.service_slug },
    props: { entry: l },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
const sensitive = data.content_guardrails === "sensitive";
const heroImage = data.hero || serviceImage(data.service_slug, "/images/hero-bg.webp");

// The quotable dispatch claim — rendered as a callout right after the hero AND
// repeated verbatim in the LocalBusiness schema description (competitor
// teardown: one consistent sentence AI engines can cite for "who serves
// {city}?"). All phrasing is data-gated in ~/lib/dispatch — 24/7 + IICRC
// wording only appears when brand.ts actually backs it up.
const dispatch = dispatchSentence(data.city);

// Guarantee a localized response-time FAQ on every service-area page — the "how fast
// can you arrive in {city}?" question people actually ask. Visible + folded into the
// FAQPage schema, and consistent with the 60-min CtaBanner copy below. 24/7
// restoration brands only — scheduled-hours trades make no emergency claim.
const responseFaq = is247
  ? [
      {
        question: `How fast can you arrive for ${data.service_display.toLowerCase()} in ${data.city}?`,
        answer: `We offer 24/7 emergency response and typically arrive on-site in ${data.city}, ${data.state} within about 60 minutes of your call — often sooner for active water, fire, or storm damage.`,
      },
    ]
  : [];

// Standard insurance FAQ — appended ONLY when the page's own frontmatter has no
// insurance question (no duplication), and only for 24/7 restoration brands
// that actually bill insurers directly (mirrors the emergency page's language).
const baseFaq = Array.isArray(data.faq) ? data.faq : [];
const hasInsuranceFaq = baseFaq.some((q) => /insurance/i.test(q.question));
const insuranceFaq =
  is247 && !hasInsuranceFaq
    ? [
        {
          question: `Will my homeowners insurance cover ${data.service_display.toLowerCase()} in ${data.city}?`,
          answer: `Often, yes — most homeowners policies cover sudden and accidental damage, though coverage always depends on your specific policy and the cause of the loss. We work with all major insurance carriers, bill them directly, and document the damage with photos and moisture readings so your ${data.city} adjuster has everything needed to process the claim.`,
        },
      ]
    : [];

const faq = [...responseFaq, ...baseFaq, ...insuranceFaq];
---

<BaseLayout
  title={data.title}
  meta_description={data.meta_description}
  hero_image_url={heroImage}
  schema_stubs={["service", "local-business", "faq", "breadcrumb-list"]}
  schema_ctx={{
    archetype: "service-area-service",
    service_display: data.service_display,
    city: data.city,
    state: data.state,
    dispatch_sentence: dispatch,
    date_modified: data.generated_at,
  }}
  breadcrumb={data.breadcrumb}
  faq={faq}
>
  <!-- HERO -->
  <section class="relative min-h-[500px] flex items-center overflow-hidden bg-white border-b border-dark/10">
    <div class="absolute inset-0 z-0">
      <img src={heroImage} alt={data.h1} class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-white/95 via-white/80 to-white/25"></div>
    </div>
    <div class="container-wide relative z-10 py-20">
      <div class="max-w-2xl">
        <div class="eyebrow">{data.city}, {data.state} · {data.service_display}</div>
        <h1 class="mb-6">{data.h1}</h1>
        <p class="text-lg text-dark/85 mb-8 leading-relaxed">{data.meta_description}</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={`tel:${brand.phoneRaw}`} class={sensitive ? "btn-primary" : "btn-accent"}>
            {sensitive ? "Request Discreet Help" : `📞 Call ${brand.phone}`}
          </a>
          <a href={`/service-areas/${data.area_slug}/`} class="btn-outline">
            All Services in {data.city}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- BODY -->
  <section class="section-first bg-white">
    <div class="container-wide">
      <div class="max-w-content mx-auto mb-10">
        <DispatchCallout sentence={dispatch} />
      </div>
      <div class="prose-body">
        <Content />
      </div>
    </div>
  </section>

  <GbpCityProof city={data.city} />

  <GoogleMap city={data.city} state={data.state} service={data.service_display} />

  <FAQSection faq={faq} eyebrow={`${data.service_display} in ${data.city}`} />

  <CtaBanner
    heading={is247 ? `${data.service_display} response in ${data.city}` : `${data.service_display} in ${data.city}`}
    subheading={is247
      ? `Most ${data.city} calls see a technician on-site within 60 minutes from our ${brand.primaryCity} headquarters.`
      : `Our crews are based in ${brand.primaryCity}, ${brand.primaryState} and take on projects across ${data.city}. Call for a free estimate.`}
  />

  <InternalLinks paths={data.internal_links} heading="Nearby & Related" eyebrow="More Coverage" />
</BaseLayout>
