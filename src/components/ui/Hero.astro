---
// src/components/ui/Hero.astro
import { brand } from "~/lib/brand";
import { srcsetFor } from "~/lib/images";
import { Phone } from "@lucide/astro";

interface Props {
  title: string;
  subtitle?: string;
  isSensitive?: boolean;
  backgroundImage?: string;
}

const { title, subtitle, isSensitive = false, backgroundImage } = Astro.props;

// Responsive variants (generated by scripts/resize_images.py). Full-bleed
// background sized by the container, so srcset/sizes only — no width/height.
const bg = backgroundImage ? srcsetFor(backgroundImage) : {};
---

<header class="relative overflow-hidden border-t border-dark/10 min-h-[60vh] md:min-h-[560px] md:h-[calc(100vh-188px)] flex items-center">
  {backgroundImage ? (
    <div class="absolute inset-0 z-0">
      <img src={backgroundImage} srcset={bg.srcset} sizes={bg.srcset ? "100vw" : undefined} alt="Background" loading="eager" fetchpriority="high" decoding="async" class="w-full h-full object-cover object-[center_25%]" />
      <div class="absolute inset-0 bg-white/20"></div>
    </div>
  ) : (
    <div class="absolute inset-0 bg-white z-0"></div>
  )}

  {/* Left-to-right scrim: strong behind the text block, light over the branded van */}
  <div class="absolute inset-0 bg-gradient-to-r from-white/85 via-white/45 to-white/10 z-0"></div>

  <div class="container-wide relative z-10 pt-10 pb-14 md:pt-12 md:pb-16 text-left">
    <div class="max-w-2xl">
      <h1 class="mb-6 drop-shadow-lg text-4xl md:text-5xl lg:text-6xl">{title}</h1>
      {subtitle && <p class="text-xl md:text-2xl text-dark/90 mb-10 drop-shadow-md">{subtitle}</p>}
      <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center flex-wrap">
        <a
          href={`tel:${brand.phoneRaw}`}
          class={`group inline-flex flex-col items-center justify-center rounded-xl shadow-[0_0_40px_rgba(220,38,38,0.4)] px-8 py-3 transition-transform hover:-translate-y-1 border-2 border-white ${isSensitive ? "bg-dark-700 hover:bg-dark-600" : "bg-primary-600 hover:bg-primary-700"}`}
        >
          <span class="text-xs md:text-sm font-bold uppercase tracking-widest text-white mb-1">{brand.ctaLabel}</span>
          <span class="text-2xl sm:text-3xl md:text-4xl font-black tracking-tight whitespace-nowrap flex items-center gap-3 text-white">
            <div class="bg-white text-primary-600 rounded-full p-2 shadow-inner">
              <Phone size={24} strokeWidth={3} />
            </div>
            {brand.phone}
          </span>
        </a>
      </div>
    </div>
  </div>
</header>
