---
// "Recent Work" gallery — real job photos uploaded by the crew via the intake link
// (branding/{cid}/job-photos), pulled in at build time. Renders nothing if there
// are no photos yet, so it never shows an empty section.
import { brand } from "~/lib/brand";
import { srcsetFor } from "~/lib/images";

const photos = (brand.jobPhotos || []).slice(0, 12);
---

{photos.length >= 3 && (
  <section class="section bg-dark-50 border-t border-dark/10">
    <div class="container-wide">
      <div class="mb-8">
        <div class="eyebrow">Recent Work</div>
        <h2>Real jobs from our {brand.primaryCity} crews</h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
        {photos.map((src) => {
          const img = srcsetFor(src);
          return (
            <div class="relative aspect-square rounded-xl overflow-hidden border border-dark/10 shadow-lg bg-dark/5">
              <img
                src={src}
                srcset={img.srcset}
                sizes={img.srcset ? "(min-width:1024px) 25vw, (min-width:640px) 33vw, 50vw" : undefined}
                width={img.width}
                height={img.height}
                alt={`${brand.displayName} — recent ${brand.primaryCity} job`}
                class="w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
          );
        })}
      </div>
    </div>
  </section>
)}
