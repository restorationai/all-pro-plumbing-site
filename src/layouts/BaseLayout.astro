---
import "~/styles/global.css";
import { brand } from "~/lib/brand";
import Analytics from "~/components/Analytics.astro";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import Schema from "~/components/Schema.astro";
import Breadcrumb from "~/components/Breadcrumb.astro";
import { Phone } from "@lucide/astro";
import type { PageSchemaContext } from "~/lib/schema";

type Props = {
  title: string;
  meta_description: string;
  canonical_url?: string;
  hero_image_url?: string;
  schema_stubs?: string[];
  schema_ctx?: Partial<PageSchemaContext>;
  breadcrumb?: { name: string; url?: string }[];
  faq?: { question: string; answer: string }[];
  noindex?: boolean;
};

const {
  title,
  meta_description,
  canonical_url,
  hero_image_url,
  schema_stubs = [],
  schema_ctx = {},
  breadcrumb,
  faq,
  noindex = false,
} = Astro.props;

const fullCanonical = canonical_url ?? `${brand.canonicalUrl}${Astro.url.pathname}`;
const rawOgImage = hero_image_url ?? `${brand.imagesBase}/brand/hero.webp`;
// og:image/twitter:image must be ABSOLUTE (audit: og_image_relative_url) —
// social scrapers don't resolve site-relative paths, so shares showed no image.
const ogImage = rawOgImage.startsWith("http")
  ? rawOgImage
  : new URL(rawOgImage, brand.canonicalUrl).href;

// Keep the rendered <title> at or under 65 chars (audit: title_length_over_65 on
// every page). Plan-generated titles are "{descriptor} | {brand}" compositions;
// shorten them here rather than editing hundreds of content files.
function fitTitle(raw: string): string {
  const MAX = 65;
  let t = raw.trim();
  if (t.length <= MAX) return t;
  // 1) Swap the full display name for the short name when they differ.
  if (brand.shortName && brand.shortName !== brand.displayName && t.includes(brand.displayName)) {
    t = t.split(brand.displayName).join(brand.shortName);
    if (t.length <= MAX) return t;
  }
  // 2) Drop a " | "-delimited segment that is exactly the brand name — the
  //    remaining segment keeps the page's keyword phrasing.
  let parts = t.split(" | ").map((p) => p.trim());
  if (parts.length > 1) {
    const brandNames = [brand.displayName, brand.shortName, brand.legalName].filter(Boolean);
    const kept = parts.filter((p) => !brandNames.includes(p));
    if (kept.length > 0 && kept.length < parts.length) {
      parts = kept;
      t = parts.join(" | ");
      if (t.length <= MAX) return t;
    }
  }
  // 3) Drop trailing segments until it fits.
  while (t.length > MAX && parts.length > 1) {
    parts = parts.slice(0, -1);
    t = parts.join(" | ");
  }
  if (t.length <= MAX) return t;
  // 4) Last resort: truncate on a word boundary.
  const cut = t.slice(0, MAX + 1);
  const space = cut.lastIndexOf(" ");
  return (space > 40 ? cut.slice(0, space) : t.slice(0, MAX)).trim();
}
const pageTitle = fitTitle(title);

// Google Fonts stylesheet URL — loaded non-render-blocking below (audit:
// render_blocking_resources; was a blocking @import in global.css).
const fontsHref = "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap";

// Only claim "Licensed & Insured" in the announcement bar when we actually
// hold license data for this client (hardcoded-claims audit).
const isLicensed = Array.isArray(brand.licenseNumbers) && brand.licenseNumbers.length > 0;

const ctx: PageSchemaContext = {
  archetype: schema_ctx.archetype ?? "unknown",
  url: Astro.url.pathname,
  title,
  meta_description,
  hero_image_url: ogImage,
  breadcrumb,
  faq,
  ...schema_ctx,
};
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" />
    <title>{pageTitle}</title>
    <meta name="description" content={meta_description} />
    <link rel="canonical" href={fullCanonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={meta_description} />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={brand.displayName} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={meta_description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Favicon set — generated from the client's real logo mark (see clients/{slug}/). */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="alternate icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {/* Web fonts, loaded without blocking first paint: preconnect + print-media
        swap trick. The blocking @import was removed from global.css. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={fontsHref} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={fontsHref} /></noscript>

    <Schema stubs={schema_stubs} ctx={ctx} />

    {/* Restoration AI Chat Widget — per-client: only renders if brand.emergencyWidgetId
        is set (the client's own company_id). Never hardcode a company_id here. */}
    {(brand as any).emergencyWidgetId && (
      <>
        <script is:inline set:html={`window.EmergencyWidgetId = ${JSON.stringify((brand as any).emergencyWidgetId)};`} />
        <script is:inline src="https://app.restorationai.io/widget-main.js" async></script>
      </>
    )}
      <Analytics />

    {/* Keep the Restoration AI chat FAB (#rai-widget-wrapper, max z-index) clear of
        the mobile sticky call bar — it otherwise overlaps the bar's right side. */}
    <style is:global>
      @media (max-width: 767px) {
        #rai-widget-wrapper {
          bottom: 76px !important;
        }
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col">
    <div class="hidden md:block bg-primary-600 text-white text-xs md:text-sm font-bold text-center py-2 px-4 tracking-wider">
      {isLicensed
        ? <>Licensed &amp; Insured &mdash; {brand.primaryCity}, {brand.primaryState} Plumbing, Heating &amp; Air Specialists</>
        : <>{brand.primaryCity}, {brand.primaryState} Plumbing, Heating &amp; Air Specialists &mdash; 24/7 Emergency Response</>}
    </div>
    <Header />
    <Breadcrumb trail={breadcrumb} />
    <main class="flex-1 pb-14 md:pb-0">
      <slot />
    </main>
    <Footer />
    <a href={`tel:${brand.phoneRaw}`} class="fixed bottom-0 inset-x-0 z-40 md:hidden flex items-center justify-center gap-3 bg-primary-600 text-white font-black py-4 text-base shadow-[0_-4px_24px_rgba(220,38,38,0.35)] border-t border-primary-700">
      <Phone size={18} strokeWidth={3} />
      Call Now: {brand.phone}
    </a>
  </body>
</html>